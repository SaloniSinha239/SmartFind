<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Submit an ownership claim for a found item.">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <%- include('../partials/toast') %>

  <main class="main-content">
    <div class="container container--narrow">
      <div class="form-card" style="max-width:640px;">
        <h1 class="form-card__title">📋 Submit Claim</h1>
        <p class="text-muted text-center mb-3">Provide proof that this item belongs to you</p>

        <div id="itemSummary" class="mb-3" style="background:var(--bg-surface);border-radius:var(--radius-sm);padding:16px;">
          <div class="spinner" style="margin:8px auto;"></div>
        </div>

        <form id="claimForm" novalidate>
          <input type="hidden" id="itemId" value="<%= itemId %>">

          <div class="form-group">
            <label for="proofText">Proof of Ownership <span class="required">*</span> <small style="color:var(--text-muted)">(min 30 chars)</small></label>
            <textarea id="proofText" name="proofText" class="form-control" rows="4"
              placeholder="Describe distinguishing marks, serial number, purchase details, or any proof that this is your item..."
              required minlength="30" aria-label="Proof of ownership"></textarea>
            <div style="text-align:right;font-size:0.75rem;color:var(--text-muted);">
              <span id="proofCount">0</span> chars
            </div>
            <div class="form-error" id="proofTextError"></div>
          </div>

          <div class="form-group">
            <label>Proof Image <small style="color:var(--text-muted)">(optional)</small></label>
            <input type="file" id="proofImage" accept="image/*" class="form-control" aria-label="Proof image">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="contactPhone">Contact Phone</label>
              <input type="tel" id="contactPhone" name="contactPhone" class="form-control" placeholder="+91 ..." aria-label="Contact phone">
            </div>
            <div class="form-group">
              <label for="pickupDate">Preferred Pickup Date</label>
              <input type="datetime-local" id="pickupDate" name="pickupDate" class="form-control" aria-label="Pickup date">
            </div>
          </div>

          <button type="submit" class="btn btn--primary btn--full btn--lg mt-2" id="claimBtn">Submit Claim</button>
        </form>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    const itemId = '<%= itemId %>';

    // Load item summary
    async function loadItemSummary() {
      try {
        const res = await fetch('/api/items/' + itemId);
        const data = await res.json();
        if (data.item) {
          const item = data.item;
          document.getElementById('itemSummary').innerHTML = `
            <div style="display:flex;gap:12px;align-items:center;">
              <img src="/api/items/${item._id}/image" alt="${item.name}"
                style="width:64px;height:64px;object-fit:cover;border-radius:8px;">
              <div>
                <h4 style="margin:0;">${item.name}</h4>
                <p style="margin:2px 0;font-size:0.8rem;color:var(--text-secondary);">${item.category} · ${item.locationLabel || 'Campus'}</p>
                <span class="badge badge--${item.status}">${item.status}</span>
              </div>
            </div>
          `;
        }
      } catch (e) {}
    }
    loadItemSummary();

    // Proof text counter
    document.getElementById('proofText').addEventListener('input', (e) => {
      document.getElementById('proofCount').textContent = e.target.value.length;
    });

    // Submit form
    document.getElementById('claimForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('claimBtn');

      document.querySelectorAll('.form-error').forEach(el => { el.textContent = ''; el.classList.remove('visible'); });

      const proofText = document.getElementById('proofText').value.trim();
      if (!proofText || proofText.length < 30) {
        const errEl = document.getElementById('proofTextError');
        errEl.textContent = 'Proof must be at least 30 characters.';
        errEl.classList.add('visible');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Submitting...';

      const formData = new FormData();
      formData.append('itemId', itemId);
      formData.append('proofText', proofText);
      formData.append('contactPhone', document.getElementById('contactPhone').value);
      formData.append('pickupDate', document.getElementById('pickupDate').value);

      const proofImageFile = document.getElementById('proofImage').files[0];
      if (proofImageFile) formData.append('proofImage', proofImageFile);

      try {
        const res = await fetch('/api/claims', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();

        if (res.ok) {
          showToast('Claim submitted successfully! 🎉', 'success');
          setTimeout(() => window.location.href = '/items/' + itemId, 1200);
        } else {
          showToast(data.error || 'Failed to submit claim.', 'error');
          btn.disabled = false;
          btn.textContent = 'Submit Claim';
        }
      } catch (err) {
        showToast('Network error. Please try again.', 'error');
        btn.disabled = false;
        btn.textContent = 'Submit Claim';
      }
    });
  </script>
</body>
</html>
