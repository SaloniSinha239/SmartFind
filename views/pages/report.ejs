<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Report a lost or found item on campus.">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <%- include('../partials/toast') %>

  <main class="main-content">
    <div class="container container--narrow">
      <div class="form-card" style="max-width:640px;">
        <h1 class="form-card__title">Report an Item</h1>
        <form id="reportForm" novalidate>
          <!-- Type -->
          <div class="form-group">
            <label>Item Type <span class="required">*</span></label>
            <div class="radio-group">
              <div class="radio-option">
                <input type="radio" name="type" id="typeLost" value="lost" required>
                <label for="typeLost">🔴 Lost</label>
              </div>
              <div class="radio-option">
                <input type="radio" name="type" id="typeFound" value="found">
                <label for="typeFound">🟢 Found</label>
              </div>
            </div>
            <div class="form-error" id="typeError"></div>
          </div>

          <!-- Category -->
          <div class="form-group">
            <label for="category">Category <span class="required">*</span></label>
            <select id="category" name="category" class="form-control" required aria-label="Item category">
              <option value="">Select category</option>
              <option value="electronics">📱 Electronics</option>
              <option value="clothing">👕 Clothing</option>
              <option value="accessories">👜 Accessories</option>
              <option value="documents">📄 Documents</option>
              <option value="other">📦 Other</option>
            </select>
            <div class="form-error" id="categoryError"></div>
          </div>

          <!-- Name -->
          <div class="form-group">
            <label for="itemName">Item Name <span class="required">*</span></label>
            <input type="text" id="itemName" name="name" class="form-control" placeholder="e.g. MacBook Pro, Student ID Card" required aria-label="Item name">
            <div class="form-error" id="itemNameError"></div>
          </div>

          <!-- Description -->
          <div class="form-group">
            <label for="description">Description <span class="required">*</span> <small style="color:var(--text-muted)">(min 20 chars)</small></label>
            <textarea id="description" name="description" class="form-control" placeholder="Describe the item in detail — color, brand, distinguishing marks..." required minlength="20" maxlength="1000" aria-label="Item description"></textarea>
            <div style="text-align:right;font-size:0.75rem;color:var(--text-muted);">
              <span id="descCount">0</span>/1000
            </div>
            <div class="form-error" id="descriptionError"></div>
          </div>

          <!-- Tags -->
          <div class="form-group">
            <label for="tags">Tags <small style="color:var(--text-muted)">(comma-separated)</small></label>
            <input type="text" id="tags" name="tags" class="form-control" placeholder="e.g. silver, apple, laptop" aria-label="Item tags">
          </div>

          <!-- Date/time -->
          <div class="form-row">
            <div class="form-group">
              <label for="dateTime">Date & Time</label>
              <input type="datetime-local" id="dateTime" name="dateTime" class="form-control" aria-label="Date and time">
            </div>
            <div class="form-group">
              <label for="contactEmail">Contact Email</label>
              <input type="email" id="contactEmail" name="contactEmail" class="form-control" placeholder="Optional" aria-label="Contact email">
            </div>
          </div>

          <!-- Location -->
          <div class="form-row">
            <div class="form-group">
              <label for="locationLabel">Location Name</label>
              <input type="text" id="locationLabel" name="locationLabel" class="form-control" placeholder="e.g. Library Block B" aria-label="Location name">
            </div>
            <div class="form-group">
              <label>GPS Coordinates</label>
              <div style="display:flex;gap:8px;">
                <input type="text" id="locationLat" name="locationLat" class="form-control" placeholder="Latitude" aria-label="Latitude" readonly>
                <input type="text" id="locationLng" name="locationLng" class="form-control" placeholder="Longitude" aria-label="Longitude" readonly>
              </div>
              <button type="button" class="btn btn--outline btn--sm mt-1" id="getLocationBtn" onclick="getLocation()">📍 Get My Location</button>
              <div class="form-error" id="locationError"></div>
            </div>
          </div>

          <!-- Private Notes (for admin comparison) -->
          <div class="form-group">
            <label for="privateNotes">Private Notes <small style="color:var(--text-muted)">(only visible to admin for claim verification)</small></label>
            <textarea id="privateNotes" name="privateNotes" class="form-control" placeholder="Distinguishing marks, serial number, etc." rows="2" aria-label="Private notes"></textarea>
          </div>

          <!-- Image Upload -->
          <div class="form-group">
            <label>Item Photo <span class="required">*</span></label>
            <div class="upload-area" id="uploadArea">
              <input type="file" id="imageInput" accept="image/jpeg,image/png,image/webp" style="display:none" aria-label="Upload item photo">
              <div class="upload-area__icon">📸</div>
              <p class="upload-area__text">
                <strong>Click to upload</strong> or drag & drop<br>
                <small>JPEG, PNG, WebP — max 5 MB</small>
              </p>
              <img class="upload-area__preview" id="imagePreview" alt="Preview">
              <div class="upload-area__progress" id="uploadProgress"></div>
            </div>
            <div class="form-error" id="imageError"></div>
          </div>

          <button type="submit" class="btn btn--primary btn--full btn--lg mt-2" id="submitBtn">🚀 Submit Report</button>
        </form>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    const uploadArea = document.getElementById('uploadArea');
    const imageInput = document.getElementById('imageInput');
    const imagePreview = document.getElementById('imagePreview');
    let selectedFile = null;
    let imageBase64 = null;

    // Description character counter
    document.getElementById('description').addEventListener('input', (e) => {
      document.getElementById('descCount').textContent = e.target.value.length;
    });

    // Upload area click
    uploadArea.addEventListener('click', () => imageInput.click());

    // Drag and drop
    uploadArea.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('upload-area--dragover');
    });
    uploadArea.addEventListener('dragleave', () => {
      uploadArea.classList.remove('upload-area--dragover');
    });
    uploadArea.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.classList.remove('upload-area--dragover');
      if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
    });

    imageInput.addEventListener('change', (e) => {
      if (e.target.files.length) handleFile(e.target.files[0]);
    });

    function handleFile(file) {
      const allowed = ['image/jpeg', 'image/png', 'image/webp'];
      if (!allowed.includes(file.type)) {
        showFieldError('image', 'Only JPEG, PNG, and WebP images are allowed.');
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        showFieldError('image', 'Image must be under 5 MB.');
        return;
      }
      selectedFile = file;
      const reader = new FileReader();
      reader.onload = (e) => {
        imageBase64 = e.target.result;
        imagePreview.src = imageBase64;
        uploadArea.classList.add('upload-area--has-file');
        clearFieldError('image');
      };
      reader.readAsDataURL(file);
    }

    // Geolocation
    function getLocation() {
      if (!navigator.geolocation) {
        showToast('Geolocation not supported by your browser.', 'error');
        return;
      }
      const btn = document.getElementById('getLocationBtn');
      btn.textContent = 'Locating...';
      btn.disabled = true;
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          document.getElementById('locationLat').value = pos.coords.latitude.toFixed(6);
          document.getElementById('locationLng').value = pos.coords.longitude.toFixed(6);
          btn.textContent = '✅ Location Set';
          btn.disabled = false;
        },
        (err) => {
          showToast('Could not get location. Please allow location access.', 'error');
          // Set default campus coordinates
          document.getElementById('locationLat').value = '28.545600';
          document.getElementById('locationLng').value = '77.192600';
          btn.textContent = '📍 Get My Location';
          btn.disabled = false;
        }
      );
    }

    // Auto-fill location on page load
    getLocation();

    // Form submit
    document.getElementById('reportForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');

      // Clear errors
      document.querySelectorAll('.form-error').forEach(el => { el.textContent = ''; el.classList.remove('visible'); });
      document.querySelectorAll('.form-control').forEach(el => el.classList.remove('form-control--error'));

      // Validate
      let valid = true;
      const type = document.querySelector('input[name="type"]:checked')?.value;
      if (!type) { showFieldError('type', 'Select Lost or Found.'); valid = false; }
      if (!document.getElementById('category').value) { showFieldError('category', 'Select a category.'); valid = false; }
      if (!document.getElementById('itemName').value.trim()) { showFieldError('itemName', 'Item name is required.'); valid = false; }
      const desc = document.getElementById('description').value.trim();
      if (!desc || desc.length < 20) { showFieldError('description', 'Description must be at least 20 characters.'); valid = false; }
      if (!imageBase64) { showFieldError('image', 'Please upload an image.'); valid = false; }
      const lat = document.getElementById('locationLat').value;
      const lng = document.getElementById('locationLng').value;
      if (!lat || !lng) { showFieldError('location', 'Location is required. Click "Get My Location".'); valid = false; }

      if (!valid) return;

      btn.disabled = true;
      btn.textContent = 'Submitting...';

      // Show progress
      const progress = document.getElementById('uploadProgress');
      progress.style.width = '30%';

      try {
        const payload = {
          type,
          category: document.getElementById('category').value,
          name: document.getElementById('itemName').value.trim(),
          description: desc,
          tags: document.getElementById('tags').value,
          locationLat: lat,
          locationLng: lng,
          locationLabel: document.getElementById('locationLabel').value.trim(),
          contactEmail: document.getElementById('contactEmail').value.trim(),
          privateNotes: document.getElementById('privateNotes').value.trim(),
          imageBase64
        };

        progress.style.width = '60%';

        const res = await fetch('/api/items', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        progress.style.width = '90%';
        const data = await res.json();

        if (res.ok) {
          progress.style.width = '100%';
          showToast('Item reported successfully! 🎉', 'success');
          setTimeout(() => window.location.href = '/items/' + data.itemId, 1200);
        } else {
          showToast(data.error || 'Failed to submit report.', 'error');
          progress.style.width = '0%';
          btn.disabled = false;
          btn.textContent = '🚀 Submit Report';
        }
      } catch (err) {
        showToast('Network error. Please try again.', 'error');
        progress.style.width = '0%';
        btn.disabled = false;
        btn.textContent = '🚀 Submit Report';
      }
    });

    function showFieldError(fieldId, message) {
      const errEl = document.getElementById(fieldId + 'Error');
      const input = document.getElementById(fieldId);
      if (errEl) { errEl.textContent = message; errEl.classList.add('visible'); }
      if (input) input.classList.add('form-control--error');
    }

    function clearFieldError(fieldId) {
      const errEl = document.getElementById(fieldId + 'Error');
      const input = document.getElementById(fieldId);
      if (errEl) { errEl.textContent = ''; errEl.classList.remove('visible'); }
      if (input) input.classList.remove('form-control--error');
    }
  </script>
</body>
</html>
