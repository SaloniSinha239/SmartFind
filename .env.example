# Environment Variables
MONGO_URI=mongodb://localhost:27017/smartfind
SESSION_SECRET=smartfind-secret-change-in-production-2026
PORT=3000

# SMTP (Nodemailer) — Use Ethereal for dev or replace with real SMTP
